        {
          "name": "Transfeera (public)",
          "item": [
            {
              "name": "POST /v1/webhooks/transfeera (auto-sign if secret set)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const secret = pm.environment.get('transfeeraWebhookSecret');",
                      "if (!secret) return;",
                      "const timestamp = String(Date.now());",
                      "const rawBody = pm.request.body?.raw ?? '';",
                      "const signedPayload = `${timestamp}.${rawBody}`;",
                      "const signatureHex = CryptoJS.HmacSHA256(signedPayload, secret).toString(CryptoJS.enc.Hex);",
                      "pm.environment.set('transfeeraWebhookTimestamp', timestamp);",
                      "pm.environment.set('transfeeraWebhookSignature', signatureHex);",
                      "pm.request.headers.upsert({ key: 'Transfeera-Signature', value: `t=${timestamp},v1=${signatureHex}` });"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"id\": \"evt_0001\",\n  \"object\": \"CashIn\",\n  \"account_id\": \"acc_demo\",\n  \"data\": {\n    \"id\": \"cashin_0001\",\n    \"txid\": \"{{txid}}\",\n    \"value\": \"1.00\",\n    \"end2end_id\": \"E2EDEMO\",\n    \"pix_key\": \"{{pixKey}}\",\n    \"payer\": {\n      \"name\": \"Cliente Teste\",\n      \"document\": \"11144477735\"\n    }\n  }\n}"
                },
                "url": "{{baseUrl}}/v1/webhooks/transfeera"
              }
            },
            {
              "name": "POST /v1/webhooks/transfeera (Infraction event)",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const secret = pm.environment.get('transfeeraWebhookSecret');",
                      "if (!secret) return;",
                      "const timestamp = String(Date.now());",
                      "const rawBody = pm.request.body?.raw ?? '';",
                      "const signedPayload = `${timestamp}.${rawBody}`;",
                      "const signatureHex = CryptoJS.HmacSHA256(signedPayload, secret).toString(CryptoJS.enc.Hex);",
                      "pm.request.headers.upsert({ key: 'Transfeera-Signature', value: `t=${timestamp},v1=${signatureHex}` });"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
