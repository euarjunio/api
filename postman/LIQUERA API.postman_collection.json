                },
                "url": "{{baseUrl}}/v1/webhooks/merchant"
              }
            },
            {
              "name": "POST /v1/webhooks/merchant (wildcard — todos eventos)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json?.webhook?.id) pm.environment.set('webhookId', json.webhook.id);",
                      "if (json?.webhook?.secret) pm.environment.set('merchantWebhookSecret', json.webhook.secret);"
