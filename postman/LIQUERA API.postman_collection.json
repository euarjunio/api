                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json?.webhook?.id) pm.environment.set('webhookId', json.webhook.id);",
                      "if (json?.webhook?.secret) pm.environment.set('merchantWebhookSecret', json.webhook.secret);",
                      "if (json?.webhook?.url) pm.environment.set('merchantWebhookUrl', json.webhook.url);"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{authToken}}" },
