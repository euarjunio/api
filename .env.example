# ============================================================
# API - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# -- Core -----------------------------------------------------
DATABASE_URL=postgresql://postgres:pdw@123@localhost:5432/gateway
NODE_ENV=development
APP_ENV=sandbox
PORT=80
API_BASE_URL=                              # Obrigatorio em producao (ex: https://api.liquera.com.br)

# -- Auth -----------------------------------------------------
JWT_SECRET=troque-por-uma-chave-segura-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=7d

# -- CORS -----------------------------------------------------
ALLOWED_ORIGINS=*                          # Em producao: "https://app.liquera.com.br,https://admin.liquera.com.br"

# -- Transfeera (Adquirente) ----------------------------------
URL_TRANSFEERA=https://sandbox-api.transfeera.com
URL_TRANSFEERA_AUTH=https://sandbox-login.transfeera.com
TRANSFEERA_CLIENT_ID=
TRANSFEERA_CLIENT_SECRET=
TRANSFEERA_CUSTOMER_ID=
PLATFORM_PIX_KEY=
PLATFORM_PIX_KEY_TYPE=EMAIL                # EMAIL | CPF | CNPJ | PHONE | CHAVE_ALEATORIA
TRANSFEERA_WEBHOOK_SECRET=                 # Obrigatorio em producao

# -- Webhooks -------------------------------------------------
MERCHANT_WEBHOOK_TIMEOUT_MS=5000
MERCHANT_WEBHOOK_MAX_RETRIES=3

# -- Redis ----------------------------------------------------
REDIS_URL=redis://localhost:6379

# -- Rate Limit -----------------------------------------------
RATE_LIMIT_GLOBAL=100                      # req/min por IP
RATE_LIMIT_CHARGE=30                       # req/min por merchant na /charge
RATE_LIMIT_AUTH=10                         # req/min por IP na /auth

# -- Settlement -----------------------------------------------
SETTLEMENT_DELAY_MS=30000                  # 30s delay para liquidar saldo
MIN_WITHDRAW_AMOUNT=100                    # Minimo em centavos (R$ 1,00)

# -- Storage (Cloudflare R2) ----------------------------------
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# -- Observability --------------------------------------------
SENTRY_DSN=                                # Obrigatorio em producao
ENABLE_SWAGGER=true                        # false em producao

# -- Seed (opcional - usado pelo prisma db seed) ---------------
SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=123123
SEED_USER_EMAIL=user@gmail.com
SEED_USER_PASSWORD=123123
SEED_MERCHANT_DOCUMENT=11144477735